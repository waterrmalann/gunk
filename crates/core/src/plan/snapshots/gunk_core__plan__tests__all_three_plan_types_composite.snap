---
source: crates/core/src/plan/tests.rs
expression: result
---
Composite:
  - Flatten:
      merge: M
      mainline_parent: D
      message: "Merge branch 'feature'\n\nMerged feature branch"
      strategy: PreserveDescendantMerges
  - FilterRepo:
      paths:
        - build/
      add_to_gitignore: true
  - Rebase:
      base: ~
      lines:
        - Pick: A
        - Pick: B
        - Drop: C
        - Pick: D
        - Pick: M
        - Pick: E
      message_map: []
      author_map: []
